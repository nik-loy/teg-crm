# Notion API
NOTION_TOKEN=ntn_your_integration_token_here

# Parent page: the Notion page that will contain all 6 databases.
# Required only for setup_notion_dbs.py. After databases are created you can leave it set.
NOTION_PARENT_PAGE_ID=your_parent_page_id_here

# Database IDs — populated by running: python -m scripts.setup_notion_dbs
NOTION_CONTACTS_DB_ID=your_database_id_here
NOTION_COMPANIES_DB_ID=your_database_id_here
NOTION_EVENTS_DB_ID=your_database_id_here
NOTION_ATTENDANCE_DB_ID=your_database_id_here
NOTION_INTERACTIONS_DB_ID=your_database_id_here
NOTION_SPEAKERS_DB_ID=your_database_id_here

# Email (Resend — free tier: 100 emails/day, 3000/month)
RESEND_API_KEY=re_your_api_key_here

# Slack (optional — webhook for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Follow-up thresholds (days)
FOLLOWUP_OVERDUE_DAYS=14
FOLLOWUP_WARNING_DAYS=7

# Team member mappings are NOT stored here.
# Use config/team.json instead (see config/team.json.example).
