# ══════════════════════════════════════════════════════════════════
# TEG CRM Web App — Environment Variables
# Copy this file to .env.local and fill in your real values.
# .env.local is in .gitignore — NEVER commit it.
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# APP AUTHENTICATION
# ──────────────────────────────────────────────
# Shared password the whole team uses to log in to the web app.
APP_PASSWORD=TEGmoney

# Random 64-char secret used to sign session cookies.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace_with_64_hex_chars_generated_by_command_above

# ──────────────────────────────────────────────
# NOTION — Integration Token
# ──────────────────────────────────────────────
# 1. Go to https://www.notion.so/profile/integrations
# 2. Click "New integration" → name it "TEG CRM" → Internal type
# 3. Capabilities: Read/Update/Insert content
# 4. Save → copy the "Internal Integration Token" (starts with ntn_)
# 5. In Notion, open each database → "..." → "Add connections" → select your integration
NOTION_TOKEN=ntn_your_integration_token_here

# ──────────────────────────────────────────────
# NOTION — Database IDs
# ──────────────────────────────────────────────
# Open each database in Notion → Share → Copy link
# The ID is the 32-char hex string in the URL before "?v="
NOTION_CONTACTS_DB_ID=your_32_char_database_id
NOTION_COMPANIES_DB_ID=your_32_char_database_id
NOTION_EVENTS_DB_ID=your_32_char_database_id
NOTION_ATTENDANCE_DB_ID=your_32_char_database_id
NOTION_INTERACTIONS_DB_ID=your_32_char_database_id
NOTION_SPEAKERS_DB_ID=your_32_char_database_id
NOTION_SCREENSHOT_INBOX_DB_ID=your_32_char_database_id

# ──────────────────────────────────────────────
# AI — OpenAI (message generation, contact extraction)
# ──────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ──────────────────────────────────────────────
# AI — Anthropic / Claude (optional fallback)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# OPTIONAL SETTINGS
# ──────────────────────────────────────────────
# Companies excluded from outreach (comma-separated, extends built-in blacklist)
OUTREACH_BLACKLIST_COMPANIES=

# Days until a pending request is flagged as stale
STALE_REQUEST_DAYS=7
