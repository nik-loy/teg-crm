# ══════════════════════════════════════════════════════════════════
# TEG CRM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# NOTION — Integration Token
# ──────────────────────────────────────────────
# 1. Go to https://www.notion.so/profile/integrations
# 2. Click "New integration" → name it "TEG CRM" → type: Internal
# 3. Under Capabilities: enable Read content, Update content, Insert content
# 4. Click Save → copy the "Internal Integration Token" (starts with ntn_)
#
# IMPORTANT: You must also connect the integration to your Notion pages.
# For each database or parent page: open it in Notion → click "..." (top right)
# → "Add connections" → select "TEG CRM". Without this the API will return 404.
#
NOTION_TOKEN=ntn_your_integration_token_here

# ──────────────────────────────────────────────
# NOTION — Parent Page ID
# ──────────────────────────────────────────────
# This is a blank Notion page that will contain all 6 CRM databases.
# Only needed once when running setup_notion_dbs.py.
#
# How to find the ID:
#   1. Create a new blank page in Notion (call it "TEG CRM" or similar)
#   2. Share the integration with this page (see IMPORTANT note above)
#   3. Open the page in your browser. The URL looks like:
#      https://www.notion.so/Your-Page-Name-abc123def456ghij78901234
#   4. The ID is the last part after the final dash — 32 hex characters.
#      Example: abc123def456ghij78901234  (no dashes needed here)
#
# Alternative: open the page → Share → Copy link → extract from URL.
#
NOTION_PARENT_PAGE_ID=your_32_char_page_id_here

# ──────────────────────────────────────────────
# NOTION — Database IDs
# ──────────────────────────────────────────────
# These are created automatically. Run this once:
#
#   python -m scripts.setup_notion_dbs
#
# The script prints all 6 IDs — paste them below.
#
# If you need to find an existing database ID manually:
#   Open the database in Notion → Share → Copy link. The URL looks like:
#   https://www.notion.so/{workspace}/{32-char-ID}?v=...
#   The 32-char hex string (before the ?v=) is the database ID.
#
NOTION_CONTACTS_DB_ID=your_database_id_here
NOTION_COMPANIES_DB_ID=your_database_id_here
NOTION_EVENTS_DB_ID=your_database_id_here
NOTION_ATTENDANCE_DB_ID=your_database_id_here
NOTION_INTERACTIONS_DB_ID=your_database_id_here
NOTION_SPEAKERS_DB_ID=your_database_id_here

# ──────────────────────────────────────────────
# EMAIL — Resend API Key
# ──────────────────────────────────────────────
# Used by the daily reminder bot and weekly report to send emails.
# Free tier: 100 emails/day, 3,000/month. No credit card required.
#
# 1. Sign up at https://resend.com
# 2. Go to API Keys → "Create API Key"
# 3. Copy the key (starts with re_)
#
# Note: you must also verify a sending domain in Resend, or use their
# onboarding address (onboarding@resend.dev) for testing only.
#
RESEND_API_KEY=re_your_api_key_here

# ──────────────────────────────────────────────
# SLACK — Webhook URL (optional)
# ──────────────────────────────────────────────
# If set, reminder notifications are also sent to this Slack channel.
#
# 1. Go to https://api.slack.com/apps → "Create New App" → "From scratch"
# 2. Enable "Incoming Webhooks" → "Add New Webhook to Workspace"
# 3. Select channel → copy the webhook URL
#
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ──────────────────────────────────────────────
# FOLLOW-UP THRESHOLDS
# ──────────────────────────────────────────────
# How many days before a follow-up triggers a warning (yellow) vs overdue (red).
# Defaults are 7 and 14 days — adjust to your team's cadence.
#
FOLLOWUP_OVERDUE_DAYS=14
FOLLOWUP_WARNING_DAYS=7

# ──────────────────────────────────────────────
# TEAM MEMBER MAPPINGS
# ──────────────────────────────────────────────
# NOT stored here. Use config/team.json instead (see config/team.json.example).
# Run python -m scripts.discover_users to find your Notion user IDs.

# ──────────────────────────────────────────────
# AI — Google Gemini
# ──────────────────────────────────────────────
# message_gen.py uses Gemini for LinkedIn outreach message generation.
# If GEMINI_API_KEY is not set, it falls back to clipboard mode.
#
# 1. Go to https://aistudio.google.com/apikey
# 2. Click "Create API key" → select a project
# 3. Copy the key
#
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────
# DJANGO — Secret Key
# ──────────────────────────────────────────────
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
DJANGO_SECRET_KEY=change-me-in-production

# ──────────────────────────────────────────────
# OUTREACH SETTINGS
# ──────────────────────────────────────────────
# Companies whose contacts are never imported (blacklist).
# Built-in: Netlight, Oliver Wyman, Accenture (confirmed speakers — don't outreach).
# Add extras as a comma-separated list to extend the built-in list.
#
OUTREACH_BLACKLIST_COMPANIES=

# Luma invite URL base — used by message_gen.py to build personalised invite links.
# The utm_source per sender is appended automatically from config/team.json.
#
OUTREACH_LUMA_URL=luma.com/71152vc3?coupon=INVITE26
