# ══════════════════════════════════════════════════════════════════
# TEG CRM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# TEAM MEMBER MAPPINGS
# ──────────────────────────────────────────────
# config/team.json holds the team member mappings. See config/team.json.example.

# ──────────────────────────────────────────────
# AI — Google Gemini
# ──────────────────────────────────────────────
# message_gen.py uses Gemini for LinkedIn outreach message generation.
# If GEMINI_API_KEY is not set, it falls back to clipboard mode.
#
# 1. Go to https://aistudio.google.com/apikey
# 2. Click "Create API key" → select a project
# 3. Copy the key
#
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────
# DJANGO — Secret Key
# ──────────────────────────────────────────────
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
DJANGO_SECRET_KEY=change-me-in-production

# ──────────────────────────────────────────────
# OUTREACH SETTINGS
# ──────────────────────────────────────────────
# Companies whose contacts are never imported (blacklist).
# Built-in: Netlight, Oliver Wyman, Accenture (confirmed speakers — don't outreach).
# Add extras as a comma-separated list to extend the built-in list.
#
OUTREACH_BLACKLIST_COMPANIES=

# Luma invite URL base — used by message_gen.py to build personalised invite links.
# The utm_source per sender is appended automatically from config/team.json.
#
OUTREACH_LUMA_URL=luma.com/71152vc3?coupon=INVITE26
