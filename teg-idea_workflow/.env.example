# =============================================================================
# TEG Idea Workflow — Environment Variables
# Copy this file to .env.local and fill in all values before running.
# All variables are REQUIRED. The app crashes at startup if any are missing.
# =============================================================================

# -----------------------------------------------------------------------------
# NOTION
# -----------------------------------------------------------------------------
# Get your integration API key from: https://www.notion.so/my-integrations
# Create a new integration, copy the "Internal Integration Secret"
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database IDs from your Notion URLs
# URL format: https://www.notion.so/{workspace}/{DATABASE_ID}?v=...
# The DATABASE_ID is the 32-character hex string before the "?"
NOTION_IDEAS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DEPT_RESPONSES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# CRON SECURITY
# -----------------------------------------------------------------------------
# A random secret shared between GitHub Actions and this Vercel app.
# Generate with: openssl rand -hex 32
# Set this SAME value as a GitHub Actions secret named CRON_SECRET.
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# EMAIL (Resend)
# -----------------------------------------------------------------------------
# Create free account at: https://resend.com
# Free tier: 3,000 emails/month, 100/day — more than enough for a student club
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for all outgoing emails.
# MUST be a verified domain/address in your Resend account.
# For a student club, you can use Resend's free shared domain initially:
# onboarding@resend.dev (only works for your own email during testing)
# For production, verify your club's domain in Resend settings.
FROM_EMAIL=workflow@teg-ev.de

# Reply-to address (optional but recommended — where replies go)
REPLY_TO_EMAIL=vorstand@teg-ev.de

# -----------------------------------------------------------------------------
# LEANTIME
# -----------------------------------------------------------------------------
# Your self-hosted Leantime instance
LEANTIME_URL=https://tegtime.myteg-ev.de

# API key from Leantime admin panel:
# Go to tegtime.myteg-ev.de → Admin → API → Generate API Key
LEANTIME_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
# Your Vercel deployment URL (no trailing slash)
# During development: http://localhost:3000
# In production: your Vercel URL e.g. https://teg-idea-workflow.vercel.app
APP_URL=https://teg-idea-workflow.vercel.app
